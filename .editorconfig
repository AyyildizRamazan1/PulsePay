# =============================================================================
# PulsePay — .editorconfig
# Enforces consistent coding style across all editors and IDEs
# https://editorconfig.org
# =============================================================================

root = true

# =============================================================================
# ALL FILES — Baseline
# =============================================================================
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

# =============================================================================
# JAVA
# =============================================================================
[*.java]
indent_style = space
indent_size  = 4
max_line_length = 120

# =============================================================================
# XML / POM
# =============================================================================
[*.{xml,xsd,xsl,wsdl}]
indent_size = 4

[pom.xml]
indent_size = 4

# =============================================================================
# YAML / PROPERTIES
# =============================================================================
[*.{yml,yaml}]
indent_size = 2

[*.properties]
indent_size = 4

# =============================================================================
# FRONTEND — JS / TS / JSX / TSX
# =============================================================================
[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

# =============================================================================
# WEB
# =============================================================================
[*.{html,css,scss,sass,less}]
indent_size = 2

# =============================================================================
# JSON
# =============================================================================
[*.json]
indent_size = 2
insert_final_newline = false

# =============================================================================
# MARKDOWN
# =============================================================================
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# =============================================================================
# SQL
# =============================================================================
[*.sql]
indent_size = 4

# =============================================================================
# SHELL SCRIPTS
# =============================================================================
[*.sh]
end_of_line  = lf
indent_size  = 2

# =============================================================================
# WINDOWS SCRIPTS
# =============================================================================
[*.{cmd,bat}]
end_of_line = crlf

# =============================================================================
# DOCKERFILE
# =============================================================================
[Dockerfile*]
indent_size = 4

# =============================================================================
# GITHUB ACTIONS / CI
# =============================================================================
[.github/**/*.{yml,yaml}]
indent_size = 2
