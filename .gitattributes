# =============================================================================
# PulsePay — .gitattributes
# Ensures consistent line endings and diff behavior across platforms
# =============================================================================

# Default: auto-normalize line endings on checkout
* text=auto

# =============================================================================
# SOURCE CODE — Force LF in repository
# =============================================================================
*.java        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.properties  text eol=lf
*.json        text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.sql         text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.sh          text eol=lf
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
.env.example  text eol=lf

# =============================================================================
# WINDOWS SCRIPTS — Keep CRLF
# =============================================================================
*.cmd         text eol=crlf
*.bat         text eol=crlf
mvnw.cmd      text eol=crlf

# =============================================================================
# BINARY FILES — No line-ending conversion
# =============================================================================
*.jar         binary
*.war         binary
*.ear         binary
*.class       binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.svg         binary
*.webp        binary
*.pdf         binary
*.zip         binary
*.gz          binary
*.tar         binary
*.p12         binary
*.jks         binary
*.pfx         binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary

# =============================================================================
# DIFF DRIVERS — Improve readability in diffs
# =============================================================================
*.java        diff=java
*.md          diff=markdown
*.xml         diff=html
