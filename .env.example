# =============================================================================
# PulsePay — .env.example
# Copy this file to .env and fill in the actual values.
# NEVER commit .env with real credentials to version control.
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulsepay
DB_USERNAME=pulsepay_user
DB_PASSWORD=changeme

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=changeme
RABBITMQ_VHOST=/

# =============================================================================
# JWT / SECURITY
# =============================================================================
JWT_SECRET=changeme-use-a-256-bit-random-string
JWT_EXPIRATION_MS=86400000

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=local
APP_PORT=8080
APP_LOG_LEVEL=INFO

# =============================================================================
# FRAUD DETECTION (SMS / Email notifications)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=noreply@pulsepay.com

# =============================================================================
# OBSERVABILITY
# =============================================================================
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=wallet-api
